---
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="container-custom section-padding">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Hakkımızda -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-accent rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <span class="font-bold text-lg" data-config="siteName">Esginler Teknik Servis</span>
        </div>
        <p class="text-blue-200 text-sm leading-relaxed mb-4">
          Bursa'nın güvenilir robot süpürge teknik servis merkezi. Segway Ninebot ve ARORA yetkili servisi olarak tüm marka ve modellerde profesyonel tamir, bakım ve orijinal yedek parça hizmeti sunuyoruz.
        </p>
        <div class="bg-green-500/15 border border-green-400/20 rounded-lg px-3 py-2.5">
          <p class="text-green-300 text-xs font-semibold flex items-center gap-1.5 mb-1">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            Pzt & Per — Ücretsiz evden cihaz alım/teslim!
          </p>
          <a href="https://teknikservis.esginler.com/servistakip" target="_blank" rel="noopener" data-config-href="servistakipUrl" class="text-green-200 hover:text-white text-xs font-medium underline">
            Evden alım randevusu al →
          </a>
        </div>
      </div>

      <!-- Hızlı Linkler -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Hızlı Linkler</h3>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-blue-200 hover:text-accent transition-colors text-sm">Anasayfa</a></li>
          <li><a href="/robot-supurge-tamiri" class="text-blue-200 hover:text-accent transition-colors text-sm">Robot Süpürge Tamiri</a></li>
          <li><a href="/robot-supurge-batarya-degisimi" class="text-blue-200 hover:text-accent transition-colors text-sm">Batarya Değişimi</a></li>
          <li><a href="/robot-supurge-bakimi" class="text-blue-200 hover:text-accent transition-colors text-sm">Robot Süpürge Bakımı</a></li>
          <li><a href="/robot-supurge-yedek-parca" class="text-blue-200 hover:text-accent transition-colors text-sm">Yedek Parça</a></li>
          <li><a href="/blog" class="text-blue-200 hover:text-accent transition-colors text-sm">Blog</a></li>
          <li><a href="/iletisim" class="text-blue-200 hover:text-accent transition-colors text-sm">İletişim</a></li>
        </ul>
      </div>

      <!-- İletişim -->
      <div>
        <h3 class="font-semibold text-lg mb-4">İletişim</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-blue-200 text-sm" data-config="address">Yenikaraman, Sanayi Cd. No:110, 16170 Osmangazi/Bursa</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href="tel:+902242112213" data-config-href="phoneRaw" class="text-blue-200 hover:text-accent transition-colors text-sm"><span data-config="phone">0224 211 22 13</span></a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.716-1.244A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.37 0-4.567-.72-6.396-1.953l-.364-.248-3.012.795.838-2.926-.272-.392A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
            <a href="https://wa.me/905545354484" target="_blank" rel="noopener" data-config-href="whatsappRaw" class="text-blue-200 hover:text-accent transition-colors text-sm"><span data-config="whatsapp">0554 535 44 84 (WhatsApp)</span></a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-blue-200 text-sm" data-config="workingHours">Pzt - Cmt: 09:00 - 18:00</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-blue-800">
    <div class="container-custom px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-blue-300 text-xs">&copy; {currentYear} <span data-config="siteName">Esginler Teknik Servis</span>. Tüm hakları saklıdır.</p>
      <p class="text-blue-300 text-xs">Bursa Robot Süpürge Teknik Servis Merkezi</p>
    </div>
  </div>
</footer>
