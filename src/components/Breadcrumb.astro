---
interface BreadcrumbItem {
  name: string;
  href?: string;
}
interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
const allItems = [{ name: 'Anasayfa', href: '/' }, ...items];
---

<nav aria-label="Breadcrumb" class="bg-light-bg border-b border-gray-100">
  <div class="container-custom px-4 py-3">
    <ol class="flex items-center gap-1.5 text-sm flex-wrap">
      {allItems.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && (
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          )}
          {item.href && i < allItems.length - 1 ? (
            <a href={item.href} class="text-primary hover:text-accent transition-colors">{item.name}</a>
          ) : (
            <span class="text-gray-500">{item.name}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<!-- BreadcrumbList Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": allItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    ...(item.href ? { "item": `https://robotsupurgetamiribursa.com${item.href}` } : {})
  }))
})} />
