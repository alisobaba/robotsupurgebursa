---
const currentPath = Astro.url.pathname;

const services = [
  { name: 'Robot Süpürge Tamiri', href: '/robot-supurge-tamiri' },
  { name: 'Batarya Değişimi', href: '/robot-supurge-batarya-degisimi' },
  { name: 'Robot Süpürge Bakımı', href: '/robot-supurge-bakimi' },
  { name: 'Yedek Parça', href: '/robot-supurge-yedek-parca' },
];

const brands = [
  { name: 'Dreame', href: '/markalar/dreame' },
  { name: 'Roborock', href: '/markalar/roborock' },
  { name: 'Xiaomi', href: '/markalar/xiaomi' },
  { name: 'Ecovacs', href: '/markalar/ecovacs' },
  { name: 'iRobot', href: '/markalar/irobot' },
  { name: 'Samsung', href: '/markalar/samsung' },
  { name: 'Dyson', href: '/markalar/dyson' },
  { name: 'Roidmi', href: '/markalar/roidmi' },
  { name: 'Segway Ninebot', href: '/markalar/segway-ninebot' },
  { name: 'ARORA', href: '/markalar/arora' },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container-custom flex items-center justify-between px-4 py-3 lg:py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div class="hidden sm:block">
        <span class="text-primary font-bold text-lg leading-tight block">Esginler</span>
        <span class="text-xs text-gray-500 leading-tight block">Teknik Servis</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1">
      <a href="/" class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath === '/' ? 'text-accent bg-orange-50' : 'text-gray-700 hover:text-accent hover:bg-orange-50'}`}>Anasayfa</a>

      <!-- Hizmetler Dropdown -->
      <div class="relative group">
        <button class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:text-accent hover:bg-orange-50 transition-colors flex items-center gap-1">
          Hizmetler
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          {services.map(s => (
            <a href={s.href} class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-orange-50 hover:text-accent first:rounded-t-lg last:rounded-b-lg">{s.name}</a>
          ))}
        </div>
      </div>

      <!-- Markalar Dropdown -->
      <div class="relative group">
        <button class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:text-accent hover:bg-orange-50 transition-colors flex items-center gap-1">
          Markalar
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 max-h-80 overflow-y-auto">
          {brands.map(b => (
            <a href={b.href} class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-orange-50 hover:text-accent first:rounded-t-lg last:rounded-b-lg">{b.name}</a>
          ))}
        </div>
      </div>

      <a href="/blog" class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath.startsWith('/blog') ? 'text-accent bg-orange-50' : 'text-gray-700 hover:text-accent hover:bg-orange-50'}`}>Blog</a>
      <a href="/iletisim" class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${currentPath === '/iletisim' ? 'text-accent bg-orange-50' : 'text-gray-700 hover:text-accent hover:bg-orange-50'}`}>İletişim</a>
    </nav>

    <!-- Phone CTA (Desktop) -->
    <a href="tel:+902242112213" class="hidden lg:inline-flex items-center gap-2 bg-accent text-white font-semibold px-4 py-2.5 rounded-lg hover:bg-orange-600 transition-colors text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      0224 211 22 13
    </a>

    <!-- Mobile Hamburger -->
    <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Menüyü aç">
      <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-gray-100">
    <div class="px-4 py-4 space-y-1">
      <a href="/" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-orange-50 hover:text-accent">Anasayfa</a>

      <div class="mobile-dropdown">
        <button class="mobile-dropdown-btn flex items-center justify-between w-full px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-orange-50 hover:text-accent">
          Hizmetler
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-dropdown-content hidden pl-4 space-y-1 mt-1">
          {services.map(s => (
            <a href={s.href} class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-orange-50 hover:text-accent">{s.name}</a>
          ))}
        </div>
      </div>

      <div class="mobile-dropdown">
        <button class="mobile-dropdown-btn flex items-center justify-between w-full px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-orange-50 hover:text-accent">
          Markalar
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-dropdown-content hidden pl-4 space-y-1 mt-1">
          {brands.map(b => (
            <a href={b.href} class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-orange-50 hover:text-accent">{b.name}</a>
          ))}
        </div>
      </div>

      <a href="/blog" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-orange-50 hover:text-accent">Blog</a>
      <a href="/iletisim" class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-orange-50 hover:text-accent">İletişim</a>

      <a href="tel:+902242112213" class="flex items-center justify-center gap-2 mt-3 bg-accent text-white font-semibold px-4 py-3 rounded-lg text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        0224 211 22 13
      </a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-dropdown-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('svg');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
