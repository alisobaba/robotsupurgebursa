---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <SEOHead {...props} />
  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1 pb-16 lg:pb-0">
    <slot />
  </main>
  <Footer />
  <MobileCTA />
  <CookieBanner />
  <script is:inline>
    window.__cookieConsentLoadAnalytics = function(cfg) {
      if (!cfg || !cfg.googleAnalyticsId || typeof cfg.googleAnalyticsId !== 'string') return;
      var id = cfg.googleAnalyticsId.trim();
      if (!id) return;
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + id;
      document.head.appendChild(s);
      s.onload = function() {
        gtag('js', new Date());
        gtag('config', id, { send_page_view: true });
      };
    };
  </script>
  <script>
    (function() {
      fetch('/config.json').then(r => r.ok ? r.json() : null).then(function(cfg) {
        if (!cfg) return;
        document.querySelectorAll('[data-config]').forEach(function(el) {
          var key = el.getAttribute('data-config');
          if (cfg[key] != null) el.textContent = cfg[key];
        });
        document.querySelectorAll('[data-config-href]').forEach(function(el) {
          var key = el.getAttribute('data-config-href');
          if (key === 'phoneRaw' && cfg.phoneRaw) el.setAttribute('href', 'tel:' + cfg.phoneRaw);
          else if (key === 'whatsappRaw' && cfg.whatsappRaw) el.setAttribute('href', 'https://wa.me/' + cfg.whatsappRaw.replace(/^\+/, ''));
          else if (key === 'servistakipUrl' && cfg.servistakipUrl) el.setAttribute('href', cfg.servistakipUrl);
        });
        var form = document.querySelector('form[data-config-formsubmit]');
        if (form && cfg.formsubmitEmail) form.setAttribute('action', 'https://formsubmit.co/' + cfg.formsubmitEmail);
        if (cfg.googleAnalyticsId && typeof cfg.googleAnalyticsId === 'string' && cfg.googleAnalyticsId.trim().length > 0) {
          var path = (window.location.pathname || '');
          if (path !== '/admin' && path.indexOf('/admin/') !== 0) {
            try {
              if (localStorage.getItem('esginler_cookie_consent') === 'accept') {
                if (typeof window.__cookieConsentLoadAnalytics === 'function') window.__cookieConsentLoadAnalytics(cfg);
              }
            } catch (e) {}
            window.addEventListener('cookie-consent-accept', function() {
              if (typeof window.__cookieConsentLoadAnalytics === 'function') window.__cookieConsentLoadAnalytics(cfg);
            });
          }
        }
      }).catch(function(){});
    })();
  </script>
</body>
</html>
