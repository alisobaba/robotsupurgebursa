---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sayfa Bulunamadı | Esginler Teknik Servis"
  description="Aradığınız sayfa mevcut değil. Bursa robot süpürge tamiri için anasayfaya dönebilirsiniz."
  noindex={true}
>
  <section class="section-padding min-h-[60vh] flex items-center">
    <div class="container-custom text-center">
      <p class="text-8xl font-bold text-primary/20 mb-4">404</p>
      <h1 class="text-2xl md:text-3xl font-bold text-primary mb-3">Sayfa Bulunamadı</h1>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">
        Aradığınız sayfa kaldırılmış veya adresi değişmiş olabilir. Robot süpürge tamiri ve bakım hizmetlerimiz için anasayfadan devam edebilirsiniz.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary inline-flex items-center justify-center gap-2">
          Anasayfaya Dön
        </a>
        <a href="/iletisim" class="px-6 py-3 border-2 border-primary text-primary font-semibold rounded-xl hover:bg-primary hover:text-white transition-colors inline-flex items-center justify-center">
          İletişim
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
