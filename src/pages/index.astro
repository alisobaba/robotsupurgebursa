      ];
      var container = document.getElementById('reviews-container');
      if (!container) return;
      var starSvg = '<svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
      function render(list) {
        if (!list || !list.length) list = defaultReviews;
        container.innerHTML = list.map(function(r, i) {
          var stars = Array(Math.min(5, Math.max(1, r.rating || 5))).fill(starSvg).join('');
          var delay = i * 100;
          return '<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md hover:-translate-y-1 opacity-0 animate-fade-in-up" style="animation-delay:' + delay + 'ms">' +
            '<div class="flex items-center gap-1 mb-3">' + stars + '</div>' +
            '<p class="text-gray-600 text-sm leading-relaxed mb-4">"' + (r.text || '').replace(/"/g, '&quot;') + '"</p>' +
            '<div class="border-t border-gray-100 pt-3"><p class="font-semibold text-primary text-sm">' + (r.name || '').replace(/</g, '&lt;') + '</p>' +
            '<p class="text-gray-400 text-xs">' + (r.device || '').replace(/</g, '&lt;') + '</p></div></div>';
        }).join('');
      }
      fetch('/reviews.json').then(function(r) { return r.ok ? r.json() : null; }).then(function(data) {
        render(Array.isArray(data) ? data : defaultReviews);
      }).catch(function() { render(defaultReviews); });
    })();
