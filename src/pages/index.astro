---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'Genel Tamir',
    desc: 'Anakart, motor ve sensör tamiri ile cihazınızı yeniden hayata döndürüyoruz.',
    href: '/robot-supurge-tamiri',
    icon: 'wrench',
  },
  {
    title: 'Batarya Değişimi',
    desc: 'Orijinal batarya değişimi ve BMS kontrol hizmeti sunuyoruz.',
    href: '/robot-supurge-batarya-degisimi',
    icon: 'battery',
  },
  {
    title: 'Sensör Tamiri',
    desc: 'LiDAR, cliff ve ultrasonik sensör arızalarını profesyonelce gideriyoruz.',
    href: '/robot-supurge-tamiri',
    icon: 'sensor',
  },
  {
    title: 'Yazılım Güncelleme',
    desc: 'Firmware güncellemesi ve fabrika ayarlarına sıfırlama işlemleri.',
    href: '/robot-supurge-tamiri',
    icon: 'code',
  },
  {
    title: 'Bakım & Temizlik',
    desc: 'Filtre, fırça değişimi ve kapsamlı genel bakım hizmeti.',
    href: '/robot-supurge-bakimi',
    icon: 'sparkle',
  },
  {
    title: 'Yedek Parça',
    desc: 'Tüm marka ve modeller için orijinal yedek parça satışı.',
    href: '/robot-supurge-yedek-parca',
    icon: 'cog',
  },
];

const brands = [
  { name: 'Dreame', href: '/markalar/dreame' },
  { name: 'Roborock', href: '/markalar/roborock' },
  { name: 'Xiaomi', href: '/markalar/xiaomi' },
  { name: 'Ecovacs', href: '/markalar/ecovacs' },
  { name: 'iRobot', href: '/markalar/irobot' },
  { name: 'Samsung', href: '/markalar/samsung' },
  { name: 'Dyson', href: '/markalar/dyson' },
  { name: 'Beko', href: '/markalar/beko' },
  { name: 'Arcelik', href: '/markalar/arcelik' },
  { name: 'Midea', href: '/markalar/midea' },
];

const advantages = [
  {
    title: 'Yetkili Servis',
    desc: 'Tüm marka ve modellerde güvenilir teknik servis merkezi olarak profesyonel hizmet.',
    icon: 'badge',
  },
  {
    title: '6+ Yıl Deneyim',
    desc: 'Binlerce robot süpürge tamiri deneyimi ile profesyonel çözümler.',
    icon: 'clock',
  },
  {
    title: 'Orijinal Yedek Parça',
    desc: 'Tüm parçalarda orijinallik garantisi, uzun ömürlü performans.',
    icon: 'shield',
  },
  {
    title: 'Hızlı Teslimat',
    desc: 'Çoğu tamirde aynı gün veya ertesi gün teslim imkanı.',
    icon: 'lightning',
  },
  {
    title: 'Ücretsiz Evden Alım',
    desc: 'Her Pazartesi ve Perşembe Bursa içi ücretsiz evden cihaz alım ve teslim hizmeti.',
    icon: 'truck',
  },
];

const steps = [
  { num: '1', title: 'İletişim', desc: 'Bizi arayın veya WhatsApp\'tan yazın. Pazartesi/Perşembe ücretsiz evden alım için randevu alın.' },
  { num: '2', title: 'Ücretsiz Teşhis', desc: 'Cihazınızı getirin veya evden alalım, arızayı ücretsiz tespit edelim.' },
  { num: '3', title: 'Onay & Tamir', desc: 'Fiyat teklifi, onayınızla tamir' },
  { num: '4', title: 'Test & Teslim', desc: 'Kapsamlı test sonrası teslim veya adresinize ücretsiz geri götürme.' },
];

const faqs = [
  {
    q: 'Robot süpürge tamiri ne kadar sürer?',
    a: 'Arızanın türüne göre değişmekle birlikte, çoğu tamir işlemi aynı gün veya ertesi gün tamamlanır. Anakart tamiri gibi daha karmaşık işlemler 2-3 iş günü sürebilir.',
  },
  {
    q: 'Tamir ücreti ne kadar?',
    a: 'Tamir ücreti arızanın türüne ve değiştirilecek parçaya göre belirlenir. Ücretsiz arıza teşhisi sonrasında detaylı fiyat bilgisi verilir. Onayınız olmadan işlem yapılmaz.',
  },
  {
    q: 'Garantisi devam eden cihazı tamir eder misiniz?',
    a: 'Garantisi devam eden cihazlar için öncelikle yetkili servise başvurmanızı öneririz. Garanti dışı durumlar veya garanti kapsamı dışındaki arızalar için hizmet vermekteyiz.',
  },
  {
    q: 'Hangi markaların tamirini yapıyorsunuz?',
    a: 'Dreame, Roborock, Xiaomi, Ecovacs, iRobot, Samsung, Dyson, Beko, Arcelik, Midea ve daha birçok markanın tamirini yapıyoruz.',
  },
  {
    q: 'Cihazımı kargo ile gönderebilir miyim?',
    a: 'Evet, Bursa dışından kargo ile cihaz gönderebilirsiniz. Cihazınızı güvenli şekilde paketleyerek kargo firmasına teslim edebilirsiniz. Tamir sonrası aynı şekilde kargoyla geri gönderilir.',
  },
  {
    q: 'Evden cihaz alım hizmetiniz var mı?',
    a: 'Evet! Her Pazartesi ve Perşembe günleri Bursa içi ücretsiz evden cihaz alım ve tamir sonrası teslim hizmeti sunuyoruz. WhatsApp veya telefon ile randevu almanız yeterli.',
  },
];
---

<BaseLayout
  title="Bursa Robot Süpürge Tamiri | Yetkili Teknik Servis - Esginler"
  description="Bursa'da Dreame, Roborock, Xiaomi, Ecovacs robot süpürge tamiri ve bakımı. Yetkili servis merkezi, orijinal yedek parça, ücretsiz arıza teşhisi. 0224 211 22 13"
  canonical="/"
>
  <Fragment slot="head">
    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Esginler Teknik Servis",
      "description": "Bursa'da robot süpürge tamiri, bakımı ve orijinal yedek parça hizmeti sunan yetkili teknik servis merkezi.",
      "url": "https://robotsupurgetamiribursa.com",
      "telephone": "+902242112213",
      "image": "https://robotsupurgetamiribursa.com/images/og-default.webp",
      "priceRange": "₺₺",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Yenikaraman, Sanayi Cd. No:110",
        "addressLocality": "Osmangazi",
        "addressRegion": "Bursa",
        "postalCode": "16170",
        "addressCountry": "TR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.22101,
        "longitude": 28.99397
      },
      "areaServed": {
        "@type": "City",
        "name": "Bursa"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
          "opens": "09:00",
          "closes": "18:00"
        }
      ]
    })} />

    <!-- FAQPage Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    })} />
  </Fragment>

  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-primary via-blue-900 to-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-10 w-72 h-72 bg-accent rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-96 h-96 bg-blue-400 rounded-full blur-3xl"></div>
    </div>
    <div class="container-custom section-padding relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="text-center lg:text-left">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
            Bursa Robot Süpürge Tamiri ve Bakımı
          </h1>
          <p class="text-lg md:text-xl text-blue-200 mb-6 leading-relaxed">
            Tüm marka ve modellerde profesyonel teknik servis. Ücretsiz arıza teşhisi.
          </p>

          <!-- Ücretsiz Alım/Teslim Vurgusu - Pazartesi & Perşembe -->
          <div class="inline-flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 bg-green-500/25 border-2 border-green-400/40 rounded-2xl px-6 py-4 mb-8 animate-soft-pulse shadow-lg shadow-green-900/20">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-green-400/30 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
              </div>
              <div>
                <span class="text-green-200 font-bold text-base sm:text-lg block">Her Pazartesi & Perşembe</span>
                <span class="text-green-300 text-sm font-medium">Ücretsiz evden cihaz alımı · Tamir sonrası adresinize teslim</span>
              </div>
            </div>
            <a href="https://teknikservis.esginler.com/servistakip" target="_blank" rel="noopener" class="bg-white text-green-700 font-bold px-5 py-2.5 rounded-xl text-sm hover:bg-green-50 transition-all hover:scale-105 shrink-0 text-center border border-green-300/50">
              Randevu Al →
            </a>
          </div>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a href="tel:+902242112213" class="btn-primary w-full sm:w-auto text-base px-8 py-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Hemen Ara
            </a>
            <a href="https://wa.me/905545354484" target="_blank" rel="noopener" class="btn-whatsapp w-full sm:w-auto text-base px-8 py-4">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.716-1.244A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              WhatsApp ile Yaz
            </a>
          </div>
          <div class="mt-6 flex items-center justify-center lg:justify-start gap-5 text-sm text-blue-200 flex-wrap">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Ücretsiz Teşhis
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Orijinal Parça
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Aynı Gün Teslim
            </span>
          </div>
        </div>

        <!-- Hero Görsel Alanı — 600x500 -->
        <div class="hidden lg:block">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 overflow-hidden aspect-[6/5] flex items-center justify-center">
            <!-- RESIM: hero-servis-atolyesi.webp — 600x500px — Servis atölyesi veya robot süpürge tamiri görseli -->
            <img src="/images/hero-servis-atolyesi.webp" alt="Bursa robot süpürge tamir servisi" class="w-full h-full object-cover" loading="eager" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            <div class="hidden flex-col items-center justify-center text-center p-8 w-full h-full">
              <svg class="w-16 h-16 text-white/30 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <span class="text-white/40 text-sm font-medium">Görsel Alanı</span>
              <span class="text-white/30 text-xs mt-1">600 x 500 px</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ÜCRETSİZ EVDEN ALIM BANTI - Pazartesi & Perşembe vurgusu -->
  <section class="bg-gradient-to-r from-green-600 to-green-700 py-5 shadow-inner">
    <div class="container-custom px-4">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-white">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          </div>
          <div>
            <span class="font-bold text-lg sm:text-xl block">Her Pazartesi & Perşembe</span>
            <span class="text-green-100 text-sm">Bursa içi ücretsiz evden alım · Tamir sonrası teslim</span>
          </div>
        </div>
        <a href="https://teknikservis.esginler.com/servistakip" target="_blank" rel="noopener" class="bg-white text-green-700 font-bold px-6 py-3 rounded-xl text-base hover:bg-green-50 transition-all hover:scale-105 shadow-lg flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Evden Alım Randevusu Al
        </a>
      </div>
    </div>
  </section>

  <!-- HİZMETLER -->
  <section class="section-padding bg-light-bg">
    <div class="container-custom">
      <div class="text-center mb-12 opacity-0 animate-fade-in-up">
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-3">Hizmetlerimiz</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Robot süpürgenizin tüm sorunlarına profesyonel çözümler sunuyoruz.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <a href={s.href} class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-lg border border-gray-100 transition-all duration-300 hover:-translate-y-2 hover:border-accent/30 opacity-0 animate-fade-in-up" style={`animation-delay: ${i * 80}ms`}>
            <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent transition-colors">
              {s.icon === 'wrench' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
              {s.icon === 'battery' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
              {s.icon === 'sensor' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
              {s.icon === 'code' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>}
              {s.icon === 'sparkle' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>}
              {s.icon === 'cog' && <svg class="w-6 h-6 text-accent group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>}
            </div>
            <h3 class="font-semibold text-lg text-primary mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-3">{s.desc}</p>
            <span class="text-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Detaylı Bilgi
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DESTEKLENEN MARKALAR -->
  <section class="section-padding">
    <div class="container-custom">
      <div class="text-center mb-12 opacity-0 animate-fade-in-up">
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-3">Desteklenen Markalar</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Tüm popüler robot süpürge markalarında uzman teknik servis hizmeti.</p>
