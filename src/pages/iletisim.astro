---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="İletişim | Esginler Teknik Servis - Bursa Robot Süpürge Tamiri"
  description="Esginler Teknik Servis iletişim bilgileri. Bursa robot süpürge tamiri için bizi arayın. Adres, telefon, WhatsApp, çalışma saatleri."
  canonical="/iletisim"
>
  <Breadcrumb items={[{ name: 'İletişim' }]} />

  <section class="section-padding">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-primary mb-3">Bursa Robot Süpürge Tamiri İletişim</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">Robot süpürgenizle ilgili sorularınız mı var? Bize ulaşın, yardımcı olalım.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- İletişim Bilgileri -->
        <div class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-light-bg rounded-xl p-6 border border-gray-100">
              <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <h3 class="font-semibold text-primary mb-1">Telefon</h3>
              <a href="tel:+902242112213" class="text-gray-600 hover:text-accent transition-colors">0224 211 22 13</a>
            </div>

            <div class="bg-light-bg rounded-xl p-6 border border-gray-100">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.638l4.716-1.244A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              </div>
              <h3 class="font-semibold text-primary mb-1">WhatsApp</h3>
              <a href="https://wa.me/905545354484" target="_blank" rel="noopener" class="text-gray-600 hover:text-accent transition-colors">0554 535 44 84</a>
            </div>

            <div class="bg-light-bg rounded-xl p-6 border border-gray-100">
              <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <h3 class="font-semibold text-primary mb-1">Adres</h3>
              <p class="text-gray-600 text-sm">Yenikaraman, Sanayi Cd. No:110, 16170 Osmangazi/Bursa</p>
            </div>

            <div class="bg-light-bg rounded-xl p-6 border border-gray-100">
              <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="font-semibold text-primary mb-1">Çalışma Saatleri</h3>
              <p class="text-gray-600 text-sm">Pazartesi - Cumartesi<br>09:00 - 18:00</p>
            </div>
          </div>

          <!-- Google Maps -->
          <div class="rounded-xl overflow-hidden shadow-md border border-gray-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3046.4628083508464!2d28.993968675505457!3d40.22101097147178!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14ca39dac4cb4f6b%3A0x21dbc3044faa3aba!2sEsginler%20Otomasyon!5e0!3m2!1str!2sus!4v1773139835118!5m2!1str!2sus"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Esginler Teknik Servis Konum"
            ></iframe>
          </div>
        </div>

        <!-- İletişim Formu -->
        <div>
          <div class="bg-light-bg rounded-xl p-6 md:p-8 border border-gray-100">
            <h2 class="text-xl font-bold text-primary mb-6">Bize Yazın</h2>
            <form action="https://formsubmit.co/teknikservisesginler@gmail.com" method="POST" class="space-y-4" data-config-formsubmit>
              <input type="hidden" name="_subject" value="Yeni İletişim Formu - robotsupurgetamiribursa.com">
              <input type="hidden" name="_captcha" value="false">
              <input type="hidden" name="_next" value="https://robotsupurgetamiribursa.com/iletisim">
              <input type="text" name="_honey" style="display:none">

              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Adınız Soyadınız</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all text-sm">
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon Numaranız</label>
                <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all text-sm">
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-posta (Opsiyonel)</label>
                <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all text-sm">
              </div>

              <div>
                <label for="device" class="block text-sm font-medium text-gray-700 mb-1">Cihaz Marka / Model</label>
                <input type="text" id="device" name="device" placeholder="Örn: Dreame L10 Pro" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all text-sm">
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Arıza Açıklaması</label>
                <textarea id="message" name="message" rows="4" required placeholder="Cihazınızın arızasını kısaca açıklayın..." class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all text-sm resize-none"></textarea>
              </div>

              <button type="submit" class="btn-primary w-full text-base py-3.5">
                Gönder
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
